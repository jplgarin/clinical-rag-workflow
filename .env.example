# Copy to .env and fill in. The generator speaks the OpenAI-compatible
# chat-completions protocol, so point LLM_API_BASE at any backend that
# implements it (hosted provider, vLLM, Ollama, LM Studio, ...).

# Model name as your backend expects it.
GENERATOR_MODEL=gpt-4o-mini

# Base URL of the inference server, without a trailing slash.
LLM_API_BASE=https://api.openai.com/v1

# Bearer token for the inference server. Leave blank for local servers
# that do not require auth.
LLM_API_KEY=your_key_here

# Local embedding model (sentence-transformers). Runs offline.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Generation controls.
MAX_TOKENS=2000
TEMPERATURE=0.3

# Logging and CORS.
LOG_LEVEL=INFO
CORS_ORIGINS=*
