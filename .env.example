# Copy to .env and fill in. The generator uses the official Anthropic SDK
# and talks to Claude directly.

# Claude model id (see platform.claude.com for available models).
GENERATOR_MODEL=claude-sonnet-4-6

# Anthropic API key. Required by the generator for report generation.
ANTHROPIC_API_KEY=your_key_here

# Local embedding model (sentence-transformers). Runs offline.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Generation controls.
MAX_TOKENS=2000
TEMPERATURE=0.3

# Logging and CORS.
LOG_LEVEL=INFO
CORS_ORIGINS=*
